# Normalize line endings: always store as LF in git
* text=auto eol=lf

# SQL and code files — enforce LF
*.sql text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.env.example text eol=lf

# Windows-specific files — preserve CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff2 binary
*.woff binary
