# ============================================================
# BOM Costing Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase — Public (safe to expose to browser via NEXT_PUBLIC_)
# Find these in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase — Service Role (NEVER expose to browser)
# Used only in server-side jobs and Supabase Auth hooks
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase — Database URL (migration CLI only, NEVER in application code)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ============================================================
# Local development overrides (when running supabase start)
# These values come from `supabase status` output
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from supabase status>
# SUPABASE_SERVICE_ROLE_KEY=<service_role key from supabase status>
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
