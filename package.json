{
  "name": "bom-costing-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate-types": "supabase gen types typescript --local > backend/types/database.generated.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "check-migrations": "node scripts/check-migrations.js",
    "check-env": "node scripts/check-env.js",
    "verify-migrations": "node scripts/verify-migrations.js",
    "apply-seed": "node scripts/apply-seed.js",
    "generate-types": "node scripts/generate-types.js",
    "smoke-test": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@supabase/supabase-js": "^2.44.0",
    "@supabase/ssr": "^0.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "vitest": "^1.6.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@playwright/test": "^1.44.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.4.0"
  }
